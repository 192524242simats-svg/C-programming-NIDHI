#include <stdio.h>

void main() {
    char ch;
    scanf("%c",&ch);
    if(ch>='A'&& ch<='Z')
    {
        printf("Upper Case");
    }
    else if(ch>='a'&&ch>='z')
    {
        printf("Lower Case");
    }
    else if(ch>='0'&&ch<='9')
    {
        printf("digits");
    }
    else
    {
        printf("Special Character");
    }
}
